#criar a coluna de presença no fenotipo - SE ESTÃO OU NÃO NO OUTRO ARQUIVO DENOMINADO FENÓTIPO. AQUI TEM QUE CHAMAR O OUTRO BANCO P DENTRO DO R TAMBÉM
animaisrgparecidos <- animaisrgparecidos %>%
  mutate(
    status_fenotipo = if_else(
      RG %in% fenotipos$RGFENOTIPO,
      "está no arquivo de fenótipo",
      "não está no arquivo de fenótipo"
    )
  )

#checar se os animais com RG parecidos tem pais iguais ou diferentes
animaisrgparecidos <- animaisrgparecidos %>%
  group_by(RG_base) %>%
  mutate(
    combo_pais = paste(RGPAI, RGMAE),
    classificacao_pais = case_when(
      
      all(RGPAI == "0" & RGMAE == "0") ~ "todos 0/0",
      
      n_distinct(combo_pais) == 1 ~ "pais iguais",
      
      n_distinct(combo_pais) > 1 ~ "pais diferentes"
    )
  ) %>%
  ungroup() %>%
  select(-combo_pais)

