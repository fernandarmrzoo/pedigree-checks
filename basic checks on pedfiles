ibrary(igraph)

edges <- rbind(
  data.frame(parent = pedalteradofr$RGPAI, child = pedalteradofr$RG),
  data.frame(parent = pedalteradofr$RGMAE, child = pedalteradofr$RG)
)

# remover pais desconhecidos
edges <- edges[edges$parent != "0", ]

# manter apenas pais que existem no pedigree
edges <- edges[edges$parent %in% pedalteradofr$RG, ]

g <- graph_from_data_frame(edges, directed = TRUE)
